{
  "name": "vscode-cha",
  "displayName": "Cha - Code Smell Analyzer",
  "description": "Code smell detection and refactoring suggestions powered by cha",
  "version": "1.7.0",
  "publisher": "BenignX",
  "homepage": "https://benign.host",
  "repository": {
    "type": "git",
    "url": "https://github.com/W-Mai/Cha"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:rust",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:go",
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Cha",
      "properties": {
        "cha.path": {
          "type": "string",
          "default": "cha",
          "description": "Path to cha binary"
        },
        "cha.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable cha LSP for real-time diagnostics"
        },
        "cha.disabledPlugins": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "large_file"
          ],
          "description": "List of finding names to suppress (e.g. large_file, todo_comment, high_coupling)"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run compile -- --watch",
    "package": "npm run compile && vsce package",
    "test:download": "tsx test/download.test.ts",
    "test:e2e": "tsc -p tsconfig.test.json && node out-test/test/e2e.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "sinon": "^21.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vscode-languageclient": "^9.0.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}