{
  "name": "vscode-cha",
  "displayName": "Cha - Code Smell Analyzer",
  "description": "Code smell detection and refactoring suggestions powered by cha",
  "version": "0.1.0",
  "publisher": "w-mai",
  "repository": {
    "type": "git",
    "url": "https://github.com/W-Mai/Cha"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:rust",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:go",
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Cha",
      "properties": {
        "cha.path": {
          "type": "string",
          "default": "cha",
          "description": "Path to cha binary"
        },
        "cha.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable cha LSP for real-time diagnostics"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vscode-languageclient": "^9.0.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
