<!--
  Language switcher for the two-tree mdbook layout.

  Convention:
    English book is at:  /book/<path>
    zh-CN book is at:    /book/zh-CN/<path>

  The switcher is injected into mdbook's `.right-buttons` toolbar after the
  page renders. Entries that 404 on the alternate tree are marked
  `unavailable` and rendered as a disabled item, so the menu always shows
  every language we publish.
-->
<style>
  .lang-switcher { position: relative; display: inline-block; }
  .lang-switcher > a { cursor: pointer; }
  .lang-switcher ul {
    position: absolute; right: 0; top: 2rem; z-index: 1000;
    background: var(--bg); border: 1px solid var(--theme-popup-border, #ccc);
    border-radius: 4px; padding: .25rem 0; margin: 0;
    list-style: none; min-width: 9rem;
    box-shadow: 0 2px 6px rgba(0,0,0,.15);
    display: none;
  }
  .lang-switcher.open ul { display: block; }
  .lang-switcher li a {
    display: block; padding: .35rem .9rem;
    color: var(--fg); text-decoration: none;
    white-space: nowrap;
  }
  .lang-switcher li a:hover { background: var(--theme-hover, #eee); }
  .lang-switcher li.current a { font-weight: 600; }
  .lang-switcher li.unavailable a { opacity: .45; cursor: not-allowed; pointer-events: none; }
</style>
<script>
(function() {
  var pagePath = "{{ path }}";
  var pathToRoot = "{{ path_to_root }}";

  var langs = [
    { id: "",      label: "English"  },
    { id: "zh-CN", label: "简体中文" },
  ];

  var here = window.location.pathname;
  var current = "";
  for (var i = 0; i < langs.length; i++) {
    if (langs[i].id && here.indexOf("/" + langs[i].id + "/") !== -1) {
      current = langs[i].id; break;
    }
  }

  // The toolbar's print/github/edit icons render as `<i class="fa fa-*">`
  // glyphs from the bundled FontAwesome 4 webfont (see FontAwesome/css/
  // font-awesome.css in the build output). Use the same element so the
  // switcher inherits the toolbar's color, size, and hover styling without
  // a bespoke CSS override.
  var GLOBE_ICON = '<i class="fa fa-globe" id="lang-button"></i>';

  document.addEventListener("DOMContentLoaded", function() {
    var rb = document.querySelector(".right-buttons");
    if (!rb) return;

    var wrap = document.createElement("div");
    wrap.className = "lang-switcher";
    var btn = document.createElement("a");
    btn.setAttribute("role", "button");
    btn.setAttribute("aria-label", "Switch language");
    btn.title = "Switch language";
    btn.innerHTML = GLOBE_ICON;
    var ul = document.createElement("ul");

    var pageHtml = pagePath.replace(/\.md$/, ".html");

    langs.forEach(function(lang) {
      var li = document.createElement("li");
      if (lang.id === current) li.className = "current";
      var a = document.createElement("a");
      var bookRoot;
      if (current === "") {
        bookRoot = pathToRoot;
      } else {
        bookRoot = pathToRoot + "../";
      }
      var url = bookRoot + (lang.id ? lang.id + "/" : "") + pageHtml;
      a.href = url;
      a.textContent = lang.label;
      li.appendChild(a);
      ul.appendChild(li);

      // HEAD-probe; on 404, mark the entry as unavailable rather than hide it.
      // Keeps the menu predictable when a translation is partial or when the
      // alternate tree isn't built locally (e.g. `mdbook serve` only renders
      // one tree at a time).
      if (lang.id !== current) {
        fetch(url, { method: "HEAD" }).then(function(resp) {
          if (!resp.ok) li.className = "unavailable";
        }).catch(function() { li.className = "unavailable"; });
      }
    });

    wrap.appendChild(btn);
    wrap.appendChild(ul);
    rb.insertBefore(wrap, rb.firstChild);

    btn.addEventListener("click", function(e) {
      e.preventDefault();
      e.stopPropagation();
      wrap.classList.toggle("open");
    });
    document.addEventListener("click", function() {
      wrap.classList.remove("open");
    });
  });
})();
</script>

<!--
  Pagefind search overlay.

  mdbook's bundled elasticlunr search drops non-ASCII tokens, so the zh-CN
  tree has no working search. Pagefind 1.4 indexes both trees in CI
  (.github/workflows/web.yml). This block injects the Pagefind UI into a
  modal overlay and hijacks mdbook's search button + `s` shortcut to open
  it instead of the default search bar.

  bundlePath is computed from `path_to_root` so each tree loads its own
  index (/book/pagefind/ for English, /book/zh-CN/pagefind/ for Chinese).
-->
<link rel="stylesheet" href="{{ path_to_root }}pagefind/pagefind-ui.css" onerror="this.remove()">
<style>
  #cha-search-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.45);
    display: none;
    align-items: flex-start; justify-content: center;
    padding-top: 6rem;
  }
  #cha-search-overlay.open { display: flex; }
  #cha-search-modal {
    width: min(720px, 92vw);
    background: var(--bg); color: var(--fg);
    border: 1px solid var(--theme-popup-border, #ccc);
    border-radius: 8px; padding: 1rem 1.25rem 1.25rem;
    box-shadow: 0 12px 32px rgba(0,0,0,.25);
    max-height: 80vh; overflow: auto;
  }
  /* Pagefind UI inherits the modal background; tighten its CSS reset
     so the input doesn't fight against mdbook's font stack. */
  #cha-search-modal .pagefind-ui__form { margin-top: 0; }
</style>
<div id="cha-search-overlay" role="dialog" aria-modal="true" aria-label="Search documentation">
  <div id="cha-search-modal">
    <div id="cha-search"></div>
  </div>
</div>
<script src="{{ path_to_root }}pagefind/pagefind-ui.js" onerror="this.remove()"></script>
<script>
(function() {
  // Stand up Pagefind UI lazily — on first open — so the index isn't
  // fetched on pages where the user never invokes search.
  var initialised = false;
  function ensureInit() {
    if (initialised) return true;
    if (typeof PagefindUI === "undefined") return false;
    new PagefindUI({
      element: "#cha-search",
      showSubResults: true,
      autofocus: true,
      translations: { placeholder: "Search the docs…" },
    });
    initialised = true;
    return true;
  }

  function openOverlay() {
    var overlay = document.getElementById("cha-search-overlay");
    if (!overlay) return;
    if (!ensureInit()) return; // Pagefind UI failed to load (no /pagefind/), bail.
    overlay.classList.add("open");
    var input = overlay.querySelector("input[type='text']");
    if (input) input.focus();
  }

  function closeOverlay() {
    var overlay = document.getElementById("cha-search-overlay");
    if (overlay) overlay.classList.remove("open");
  }

  document.addEventListener("DOMContentLoaded", function() {
    var overlay = document.getElementById("cha-search-overlay");
    if (!overlay) return;

    // Click outside the modal closes it.
    overlay.addEventListener("click", function(e) {
      if (e.target === overlay) closeOverlay();
    });

    // Escape closes; `s` opens (matching mdbook's default shortcut),
    // `/` opens too (matching the convention from GitHub / many docs sites).
    document.addEventListener("keydown", function(e) {
      if (e.key === "Escape" && overlay.classList.contains("open")) {
        closeOverlay();
        e.preventDefault();
        return;
      }
      var t = e.target;
      var typing = t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA" ||
                         (t.isContentEditable === true));
      if (typing) return;
      if (e.key === "s" || e.key === "/") {
        openOverlay();
        e.preventDefault();
      }
    });

    // Hijack mdbook's search-toggle button if it exists.
    var toggle = document.getElementById("search-toggle");
    if (toggle) {
      toggle.addEventListener("click", function(e) {
        e.preventDefault();
        e.stopPropagation();
        openOverlay();
      }, true);
    }
  });
})();
</script>
